#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>


#define PAREDE '*'
#define ESPINHO '#'
#define CAIXA 'k'
#define BOTAO 'O'
#define PORTA_FECHADA 'D'
#define CHAVE '@'
#define PORTA_ABERTA '='
#define ESCADA 'L'
#define MONSTRO_1 'X'
#define MONSTRO_2 'Y'
#define BOSS 'Z'
#define VAZIO ' '


typedef struct {
    char nome[20];
    int tipo; 
} Arma;

typedef struct {
    int x, y;
    char direcao;
    int vidas;
    int chaves;
    Arma arma;
