void jogar() {
    Jogador heroi;
    heroi.vidas = 3;
    heroi.chaves = 0;
    heroi.tem_arma = 0;
    strcpy(heroi.arma.nome, "Nenhuma");
    heroi.arma.tipo = 0;

    
    rodarVila(&heroi);
    if (heroi.vidas > 0) rodarAndar1(&heroi);
    if (heroi.vidas > 0) rodarAndar2(&heroi);
    if (heroi.vidas > 0) rodarAndar3(&heroi);

    if (heroi.vidas <= 0) {
        printf("\n=================================\n");
        printf("           GAME OVER!            \n");
        printf("=================================\n");
        printf("Pressione ENTER para voltar ao menu principal.");
        getchar();
    }
}


void rodarVila(Jogador *j) {
    int tam = 10;
    char **mapa = alocarMapa(tam);
    
    
    for (int i=0; i<tam; i++) {
        for (int j=0; j<tam; j++) {
            if (i==0 || i==tam-1 || j==0 || j==tam-1) mapa[i][j] = PAREDE;
            else mapa[i][j] = VAZIO;
        }
    }
    
    
    j->x = 5; j->y = 2; j->direcao = '>';
    mapa[j->x][j->y] = '>';
    mapa[5][7] = 'N'; 
    mapa[1][5] = ESCADA; 

    int mapa_ativo = 1;
    while (mapa_ativo && j->vidas > 0) {
        desenharJogo(mapa, tam, j, 0);
        printf("Comando: ");
        char cmd;
        scanf(" %c", &cmd);

        int px = j->x, py = j->y;
        char nd = j->direcao;

        if (cmd == 'w' || cmd == 'W') { px--; nd = '^'; }
        else if (cmd == 's' || cmd == 'S') { px++; nd = 'V'; }
        else if (cmd == 'a' || cmd == 'A') { py--; nd = '<'; } // Correção para esquerda/direita nas coordenadas
        else if (cmd == 'd' || cmd == 'D') { py++; nd = '>'; }
        else if (cmd == 'i' || cmd == 'I') {
            int fx = j->x, fy = j->y;
            if (j->direcao == '^') fx--; else if (j->direcao == 'V') fx++;
            else if (j->direcao == '<') fy--; else if (j->direcao == '>') fy++;
            
            if (fx >= 0 && fx < tam && fy >= 0 && fy < tam && mapa[fx][fy] == 'N') {
                printf("\n[NPC]: Escolha sua arma:\n1 - Espada\n2 - Arco e Flecha\n3 - Cajado\nOpcao: ");
                int escolha;
                scanf("%d", &escolha);
                j->tem_arma = 1;
                if (escolha == 1) { j->arma.tipo = 1; strcpy(j->arma.nome, "Espada"); }
                else if (escolha == 2) { j->arma.tipo = 2; strcpy(j->arma.nome, "Arco e Flecha"); }
                else { j->arma.tipo = 3; strcpy(j->arma.nome, "Cajado"); }
                printf("Voce equipou o %s!\n", j->arma.nome);
                getchar(); getchar();
            }
        }

        
        if (cmd=='w'||cmd=='W'||cmd=='s'||cmd=='S'||cmd=='a'||cmd=='A'||cmd=='d'||cmd=='D') {
            if (mapa[px][py] == ESCADA) {
                if (j->tem_arma) {
                    mapa_ativo = 0; 
                } else {
                    printf("\nVoce precisa escolher uma arma com o NPC antes de entrar!\n");
                    getchar(); getchar();
                }
            } else if (mapa[px][py] == VAZIO) {
                mapa[j->x][j->y] = VAZIO;
                j->x = px; j->y = py; j->direcao = nd;
                mapa[j->x][j->y] = nd;
            } else {
                j->direcao = nd;
                mapa[j->x][j->y] = nd;
            }
        }
    }
    liberarMapa(mapa, tam);
}


void rodarAndar1(Jogador *j) {
    int tam = 10;
    char **mapa = alocarMapa(tam);
    j->chaves = 0; 

    
    for (int i=0; i<tam; i++) {
        for (int k=0; k<tam; k++) {
            if (i==0 || i==tam-1 || k==0 || k==tam-1) mapa[i][k] = PAREDE;
            else mapa[i][k] = VAZIO;
        }
    }
    
    j->x = 8; j->y = 1; j->direcao = '^';
    mapa[j->x][j->y] = '^';
    
    mapa[5][3] = CAIXA;
    mapa[5][4] = CAIXA;
    mapa[5][5] = PORTA_FECHADA;
    mapa[2][2] = CHAVE;
    mapa[2][8] = ESCADA;

    int mapa_ativo = 1;
    while (mapa_ativo && j->vidas > 0) {
        desenharJogo(mapa, tam, j, 1);
        printf("Comando: ");
        char cmd;
        scanf(" %c", &cmd);

        int px = j->x, py = j->y;
        char nd = j->direcao;

        if (cmd == 'w' || cmd == 'W') { px--; nd = '^'; }
        else if (cmd == 's' || cmd == 'S') { px++; nd = 'V'; }
        else if (cmd == 'a' || cmd == 'A') { py--; nd = '<'; }
        else if (cmd == 'd' || cmd == 'D') { py++; nd = '>'; }
        else if (cmd == 'i' || cmd == 'I') { interagirObjeto(mapa, tam, j, 1, NULL); }
        else if (cmd == 'o' || cmd == 'O') { realizarAtaque(mapa, tam, j, NULL, 0); }

        if (cmd=='w'||cmd=='W'||cmd=='s'||cmd=='S'||cmd=='a'||cmd=='A'||cmd=='d'||cmd=='D') {
            if (mapa[px][py] == ESCADA) {
                mapa_ativo = 0;
            } else if (mapa[px][py] == VAZIO || mapa[px][py] == PORTA_ABERTA || mapa[px][py] == CHAVE) {
                if (mapa[px][py] == CHAVE) j->chaves++;
                mapa[j->x][j->y] = VAZIO;
                j->x = px; j->y = py; j->direcao = nd;
                mapa[j->x][j->y] = nd;
            } else {
                j->direcao = nd;
                mapa[j->x][j->y] = nd;
            }
        }
    }
    liberarMapa(mapa, tam);
}


void rodarAndar2(Jogador *j) {
    int tam = 15;
    char **mapa = alocarMapa(tam);
    j->chaves = 0;
    int botao_pressionado = 0;

    
    for (int i=0; i<tam; i++) {
        for (int k=0; k<tam; k++) {
            if (i==0 || i==tam-1 || k==0 || k==tam-1) mapa[i][k] = PAREDE;
            else mapa[i][k] = VAZIO;
        }
    }

    j->x = 13; j->y = 7; j->direcao = '^';
    mapa[j->x][j->y] = '^';

    
    mapa[10][7] = PORTA_FECHADA;
    mapa[5][4] = PORTA_FECHADA;
    mapa[12][2] = CHAVE;
    mapa[8][12] = CHAVE;
    mapa[2][2] = BOTAO;
    mapa[1][13] = ESCADA;
    mapa[9][6] = ESPINHO; mapa[9][8] = ESPINHO;

    
    int qtd_m = 2;
    Monstro monstros[2] = {
        {4, 7, MONSTRO_1, 1},
        {3, 10, MONSTRO_1, 1}
    };
    mapa[4][7] = MONSTRO_1;
    mapa[3][10] = MONSTRO_1;

    int mapa_ativo = 1;
    while (mapa_ativo && j->vidas > 0) {
        desenharJogo(mapa, tam, j, 2);
        printf("Comando: ");
        char cmd;
        scanf(" %c", &cmd);

        int px = j->x, py = j->y;
        char nd = j->direcao;
        int mover_m = 0;

        if (cmd == 'w' || cmd == 'W') { px--; nd = '^'; mover_m = 1; }
        else if (cmd == 's' || cmd == 'S') { px++; nd = 'V'; mover_m = 1; }
        else if (cmd == 'a' || cmd == 'A') { py--; nd = '<'; mover_m = 1; }
        else if (cmd == 'd' || cmd == 'D') { py++; nd = '>'; mover_m = 1; }
        else if (cmd == 'i' || cmd == 'I') { interagirObjeto(mapa, tam, j, 2, &botao_pressionado); }
        else if (cmd == 'o' || cmd == 'O') { realizarAtaque(mapa, tam, j, monstros, qtd_m); mover_m = 1; }

        if (cmd=='w'||cmd=='W'||cmd=='s'||cmd=='S'||cmd=='a'||cmd=='A'||cmd=='d'||cmd=='D') {
            if (mapa[px][py] == ESCADA) {
                mapa_ativo = 0;
            } else if (mapa[px][py] == ESPINHO) {
                j->vidas--;
                
                liberarMapa(mapa, tam);
                rodarAndar2(j);
                return;
            } else if (mapa[px][py] == VAZIO || mapa[px][py] == PORTA_ABERTA || mapa[px][py] == CHAVE) {
                if (mapa[px][py] == CHAVE) j->chaves++;
                mapa[j->x][j->y] = VAZIO;
                j->x = px; j->y = py; j->direcao = nd;
                mapa[j->x][j->y] = nd;
            } else {
                j->direcao = nd;
                mapa[j->x][j->y] = nd;
            }
        }

        if (mover_m) {
            int reiniciar = 0;
            moverMonstros(mapa, tam, monstros, qtd_m, j, &reiniciar);
            if (reiniciar) {
                liberarMapa(mapa, tam);
                rodarAndar2(j);
                return;
            }
        }
    }
    liberarMapa(mapa, tam);
}


