void moverMonstros(char **mapa, int tam, Monstro *monstros, int qtd_monstros, Jogador *j, int *reiniciar) {
    for (int i = 0; i < qtd_monstros; i++) {
        if (!monstros[i].ativo) continue;

        int mx = monstros[i].x;
        int my = monstros[i].y;
        int prox_mx = mx;
        int prox_my = my;

        if (monstros[i].tipo == MONSTRO_1) {

            int dir = rand() % 4;
            if (dir == 0) prox_mx--; else if (dir == 1) prox_mx++;
            else if (dir == 2) prox_my--; else if (dir == 3) prox_my++;
        } 
        else if (monstros[i].tipo == MONSTRO_2) {
            
            int diff_x = j->x - mx;
            int diff_y = j->y - my;
            if (abs(diff_x) >= abs(diff_y)) {
                prox_mx += (diff_x > 0) ? 1 : -1;
            } else {
                prox_my += (diff_y > 0) ? 1 : -1;
            }
        }
        else if (monstros[i].tipo == BOSS) {
            
            if (abs(j->x - mx) <= 3 && abs(j->y - my) <= 3) {
                prox_mx = (rand() % (tam - 4)) + 2;
                prox_my = (rand() % (tam - 4)) + 2;
            } else {
                
                int diff_x = j->x - mx;
                if (diff_x != 0) prox_mx += (diff_x > 0) ? 1 : -1;
            }
        }

        
        if (prox_mx >= 0 && prox_mx < tam && prox_my >= 0 && prox_my < tam) {
            if (prox_mx == j->x && prox_my == j->y) {
                j->vidas--;
                *reiniciar = 1;
                return;
            }
            if (mapa[prox_mx][prox_my] == VAZIO) {
                mapa[mx][my] = VAZIO;
                monstros[i].x = prox_mx; monstros[i].y = prox_my;
                mapa[prox_mx][prox_my] = monstros[i].tipo;
            }
        }
    }
}


void realizarAtaque(char **mapa, int tam, Jogador *j, Monstro *monstros, int qtd_monstros) {
    if (!j->tem_arma) return;

    printf("\n[ATAQUE EXECUTADO COM %s!]\n", j->arma.nome);
    
    
    for (int i = 0; i < tam; i++) {
        for (int k = 0; k < tam; k++) {
            int atingido = 0;

            
            if (j->arma.tipo == 1) {
                if (j->direcao == '^' && (i == j->x-1 || i == j->x-2) && abs(k - j->y) <= 1) atingido = 1;
                else if (j->direcao == 'V' && (i == j->x+1 || i == j->x+2) && abs(k - j->y) <= 1) atingido = 1;
                else if (j->direcao == '<' && (k == j->y-1 || k == j->y-2) && abs(i - j->x) <= 1) atingido = 1;
                else if (j->direcao == '>' && (k == j->y+1 || k == j->y+2) && abs(i - j->x) <= 1) atingido = 1;
            }
            
            else if (j->arma.tipo == 2) {
                if (j->direcao == '^' && k == j->y && i < j->x && i >= j->x-4) atingido = 1;
                else if (j->direcao == 'V' && k == j->y && i > j->x && i <= j->x+4) atingido = 1;
                else if (j->direcao == '<' && i == j->x && k < j->y && k >= j->y-4) atingido = 1;
                else if (j->direcao == '>' && i == j->x && k > j->y && k <= j->y+4) atingido = 1;
            }
            
            else if (j->arma.tipo == 3) {
                if (abs(i - j->x) <= 1 && abs(k - j->y) <= 1 && !(i == j->x && k == j->y)) atingido = 1;
            }

            if (atingido) {
                
                if (mapa[i][k] == CAIXA) mapa[i][k] = VAZIO;
                
                
                if (monstros != NULL) {
                    for (int m = 0; m < qtd_monstros; m++) {
                        if (monstros[m].ativo && monstros[m].x == i && monstros[m].y == k) {
                            monstros[m].ativo = 0;
                            mapa[i][k] = VAZIO;
                            printf("Monstro %c foi eliminado!\n", monstros[m].tipo);
                        }
                    }
                }
            }
        }
    }
    getchar();
}


void interagirObjeto(char **mapa, int tam, Jogador *j, int andar, int *botao_pressionado) {
    int fx = j->x;
    int fy = j->y;

    if (j->direcao == '^') fx--; else if (j->direcao == 'V') fx++;
    else if (j->direcao == '<') fy--; else if (j->direcao == '>') fy++;

    if (fx < 0 || fx >= tam || fy < 0 || fy >= tam) return;

    
    if (mapa[fx][fy] == PORTA_FECHADA) {
        if (j->chaves > 0) {
            j->chaves--;
            mapa[fx][fy] = PORTA_ABERTA;
            printf("\nPorta destrancada com sucesso!\n");
        } else {
            printf("\nVoce nao tem chaves suficientes para esta porta!\n");
        }
        getchar();
    } 
    
    else if (mapa[fx][fy] == BOTAO && botao_pressionado != NULL && *botao_pressionado == 0) {
        *botao_pressionado = 1;
        printf("\n[BOTAO ATIVADO]: Uma barreira de espinhos sumiu do mapa!\n");
        if (andar == 2) {
            mapa[9][6] = VAZIO;
            mapa[9][8] = VAZIO;
        }
        getchar();
    }
}


char** alocarMapa(int tam) {
    char **mapa = (char**)malloc(tam * sizeof(char*));
    for (int i=0; i<tam; i++) mapa[i] = (char*)malloc(tam * sizeof(char));
    return mapa;
}

void liberarMapa(char **mapa, int tam) {
    for (int i=0; i<tam; i++) free(mapa[i]);
    free(mapa);
}

void desenharJogo(char **mapa, int tam, Jogador *j, int andar) {
    
    #ifdef _WIN32
        system("cls");
    #else
        system("clear");
    #endif

    printf("=== ANDAR: %d === | Vidas: %d | Chaves: %d | Arma: %s\n\n", andar, j->vidas, j->chaves, j->arma.nome);
    for (int i = 0; i < tam; i++) {
        for (int k = 0; k < tam; k++) {
            printf("%c ", mapa[i][k]);
        }
        printf("\n");
    }
    printf("\n");
}
